import nltk
import random
from nltk.util import bigrams
from nltk.tokenize import word_tokenize

nltk.download('punkt')

text = "Natural language processing is fun and language processing is powerful"

# Tokenize text
words = word_tokenize(text)

# Generate bigrams
bigram_pairs = list(bigrams(words))

# Create bigram dictionary
bigram_dict = {}

for w1, w2 in bigram_pairs:
    if w1 not in bigram_dict:
        bigram_dict[w1] = []
    bigram_dict[w1].append(w2)

# Generate text
current_word = random.choice(words)
generated_text = [current_word]

for i in range(10):
    if current_word in bigram_dict:
        next_word = random.choice(bigram_dict[current_word])
        generated_text.append(next_word)
        current_word = next_word
    else:
        break

print("Generated Text:")
print(" ".join(generated_text))
